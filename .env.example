# --- Twilio ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
# Exact public URL Twilio POSTs the webhook to (used for signature validation).
PUBLIC_BASE_URL=https://your-host.ngrok.app
VALIDATE_TWILIO_SIGNATURE=true

# --- Storage ---
DATABASE_URL=sqlite:///smsllm.db

# --- Worker ---
WORKER_POLL_SECONDS=10

# --- Defaults for new bots ---
DEFAULT_DEBOUNCE_SECONDS=300
DEFAULT_LENGTH_BUDGET_CHARS=255
DEFAULT_MAX_MESSAGES_PER_SENDER=10

# --- Global LLM-call cap (abuse / cost protection) ---
# Absolute hard ceiling across all numbers/senders (0 = disabled).
GLOBAL_MAX_LLM_CALLS_TOTAL=0
# Rolling rate cap (0 = disabled): at most N calls per window.
GLOBAL_MAX_LLM_CALLS_PER_WINDOW=0
GLOBAL_WINDOW_SECONDS=86400

# --- Provider API keys (referenced by BotConfig.api_key_ref by NAME) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
